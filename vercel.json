{
  "rewrites": [
    { "source": "/demo", "destination": "/onboarding-demo.html" },
    { "source": "/data-structures", "destination": "/onboarding-data-structures.html" },
    { "source": "/(.*)", "destination": "/verifyflow-site.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
